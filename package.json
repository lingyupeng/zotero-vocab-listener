{
  "name": "zotero-highlight-collector",
  "type": "module",
  "version": "0.2.0",
  "description": "Build a personal research dataset from Zotero PDF highlight annotations.",
  "config": {
    "addonName": "Zotero Highlight Collector",
    "addonID": "vocablistener@example.com",
    "addonRef": "vocablistener",
    "addonInstance": "VocabListener",
    "prefsPrefix": "extensions.zotero.vocablistener"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingyupeng/zotero-vocab-listener.git"
  },
  "author": "lingyupeng",
  "bugs": {
    "url": "https://github.com/lingyupeng/zotero-vocab-listener/issues"
  },
  "homepage": "https://github.com/lingyupeng/zotero-vocab-listener",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
